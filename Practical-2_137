class Student {

    int rollNo;
    String name;

    void setData(int r, String n) {
        rollNo = r;
        name = n;
    }

    void displayData() {
        System.out.println("Roll No: " + rollNo);
        System.out.println("Name: " + name);
    }
}

public class DemoClassObject {

    public static void main(String[] args) {

        Student s1 = new Student();

        s1.setData(101, "Omkar");
        s1.displayData();
    }
}
